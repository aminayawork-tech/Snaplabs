# SnapLabs Environment Variables - Copy to .env and fill in your keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Agency Settings (customize these)
AGENCY_NAME=Your Agency Name
AGENCY_EMAIL=hello@youragency.com
AGENCY_PHONE=+1 (555) 000-0000
AGENCY_WEBSITE=https://youragency.com

# Database
DATABASE_URL=sqlite:///marketingos.db

# Model settings
CLAUDE_MODEL=claude-sonnet-4-6
